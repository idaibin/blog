---
import FeedList from "@/components/FeedList.astro";
import Pagination from "@/components/Pagination.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getAllSectionPosts, getFeedPath } from "@/utils";
import { feedPageSize, getFeedPagePath, homeMeta, sectionMeta, type Locale } from "@/site";

const locale = "en" as Locale;
const feedPosts = await getAllSectionPosts(locale);
const page = {
  currentPage: 1,
  lastPage: Math.max(1, Math.ceil(feedPosts.length / feedPageSize)),
  url: {
    next:
      feedPosts.length > feedPageSize
        ? getFeedPagePath(locale, 2)
        : undefined,
  },
};

const feedItems = feedPosts.slice(0, feedPageSize).map((post) => ({
  section: post.section,
  title: post.data.title,
  description: post.data.description,
  href: getFeedPath(post.section, post.id, locale),
  pubDate: post.data.pubDate,
  featured: post.data.featured,
  tags: post.data.tags,
  audience: post.data.audience,
  heroImage: post.data.heroImage,
  cover: post.data.cover,
}));
---

<BaseLayout title="idaibin.dev" description={homeMeta.en.description}>
  <main class="page-section">
    <section class="page-intro">
      <span class="intro-kicker">AI publication system</span>
      <h1 class="intro-title">{homeMeta.en.title}</h1>
      <p class="intro-copy">{homeMeta.en.lead}</p>
      <div class="intro-meta">
        <span class="meta-chip">{feedPosts.length} items</span>
        <span class="meta-chip">All streams</span>
      </div>
    </section>

    <FeedList
      items={feedItems}
      locale={locale}
      emptyTitle="No items yet"
      emptyCopy={sectionMeta[locale].notes.summary}
    />

    {page.lastPage > 1 && <Pagination locale={locale} page={page} />}
  </main>
</BaseLayout>

<style>
  .page-intro {
    display: grid;
    gap: 0.65rem;
    max-width: 48rem;
  }

  .intro-kicker {
    color: rgb(var(--accent-dark));
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .intro-title {
    margin: 0;
    color: rgb(var(--black));
    font-size: clamp(1.7rem, 2.8vw, 2.6rem);
    line-height: 1.02;
    letter-spacing: -0.05em;
  }

  .intro-copy {
    margin: 0;
    max-width: 46rem;
    color: rgb(var(--gray-dark));
    font-size: 1.02rem;
    line-height: 1.75;
  }

  .intro-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
</style>
