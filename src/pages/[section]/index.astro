---
import FeedList from "@/components/FeedList.astro";
import Pagination from "@/components/Pagination.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getSectionCount, getSectionPosts, getFeedPath } from "@/utils";
import {
  feedPageSize,
  getFeedPagePath,
  sectionMeta,
  sections,
  type Locale,
  type SectionKey,
} from "@/site";

export async function getStaticPaths() {
  return sections.map((section) => ({
    params: { section },
  }));
}

const locale = (Astro.currentLocale || "en") as Locale;
const section = Astro.params.section as SectionKey;
const meta = sectionMeta[locale][section];
const posts = await getSectionPosts(section, locale);
const count = await getSectionCount(section, locale);
const page = {
  currentPage: 1,
  lastPage: Math.max(1, Math.ceil(posts.length / feedPageSize)),
  url: {
    next:
      posts.length > feedPageSize
        ? getFeedPagePath(locale, 2, section)
        : undefined,
  },
};

const feedItems = posts.slice(0, feedPageSize).map((post) => ({
  section,
  title: post.data.title,
  description: post.data.description,
  href: getFeedPath(section, post.id, locale),
  pubDate: post.data.pubDate,
  featured: post.data.featured,
  tags: post.data.tags,
  audience: post.data.audience,
  heroImage: post.data.heroImage,
  cover: post.data.cover,
}));
---

<BaseLayout title={`${meta.title} · idaibin.dev`} description={meta.description}>
  <main class="page-section">
    <section class="page-intro">
      <span class="intro-kicker">{meta.title}</span>
      <h1 class="intro-title">{meta.title}</h1>
      <p class="intro-copy">{meta.intro}</p>
      <div class="intro-meta">
        <span class="meta-chip">{count} items</span>
        <span class="meta-chip">{meta.summary}</span>
      </div>
    </section>

    <FeedList
      items={feedItems}
      locale={locale}
      emptyTitle={meta.title}
      emptyCopy={meta.summary}
    />

    {page.lastPage > 1 && <Pagination locale={locale} page={page} />}
  </main>
</BaseLayout>

<style>
  .page-intro {
    display: grid;
    gap: 0.65rem;
    max-width: 48rem;
  }

  .intro-kicker {
    color: rgb(var(--accent-dark));
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .intro-title {
    margin: 0;
    color: rgb(var(--black));
    font-size: clamp(1.65rem, 2.6vw, 2.4rem);
    line-height: 1.02;
    letter-spacing: -0.05em;
  }

  .intro-copy {
    margin: 0;
    max-width: 46rem;
    color: rgb(var(--gray-dark));
    font-size: 1.02rem;
    line-height: 1.75;
  }

  .intro-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
</style>
