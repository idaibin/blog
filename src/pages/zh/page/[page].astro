---
import FeedList from "@/components/FeedList.astro";
import Pagination from "@/components/Pagination.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { chunkItems, getAllSectionPosts, getFeedPath } from "@/utils";
import {
  feedPageSize,
  homeMeta,
  sectionMeta,
  type Locale,
} from "@/site";

const locale = "zh" as Locale;

export async function getStaticPaths() {
  const locale = "zh" as Locale;
  const posts = await getAllSectionPosts(locale);
  const pages = chunkItems(posts, feedPageSize);

  return pages.slice(1).map((items, index) => ({
    params: { page: String(index + 2) },
    props: {
      page: {
        currentPage: index + 2,
        lastPage: pages.length,
        total: posts.length,
        data: items,
        url: {
          prev: index === 0 ? "/zh" : `/zh/page/${index + 1}`,
          next:
            index + 2 < pages.length
              ? `/zh/page/${index + 3}`
              : undefined,
        },
      },
    },
  }));
}

const { page } = Astro.props as {
  page: {
    currentPage: number;
    lastPage: number;
    total: number;
    data: Awaited<ReturnType<typeof getAllSectionPosts>>;
    url: {
      prev?: string;
      next?: string;
    };
  };
};

const feedItems = page.data.map((post) => ({
  section: post.section,
  title: post.data.title,
  description: post.data.description,
  href: getFeedPath(post.section, post.id, locale),
  pubDate: post.data.pubDate,
  featured: post.data.featured,
  tags: post.data.tags,
  audience: post.data.audience,
  heroImage: post.data.heroImage,
  cover: post.data.cover,
}));
---

<BaseLayout title={`idaibin.dev · 第 ${page.currentPage} 页`} description={homeMeta.zh.description}>
  <main class="page-section">
    <section class="page-intro">
      <span class="intro-kicker">AI 内容系统</span>
      <h1 class="intro-title">{homeMeta.zh.title}</h1>
      <p class="intro-copy">{homeMeta.zh.lead}</p>
      <div class="intro-meta">
        <span class="meta-chip">{page.total} 篇</span>
        <span class="meta-chip">
          第 {page.currentPage} / {page.lastPage} 页
        </span>
      </div>
    </section>

    <FeedList
      items={feedItems}
      locale={locale}
      emptyTitle="暂无内容"
      emptyCopy={sectionMeta[locale].notes.summary}
    />

    <Pagination locale={locale} page={page} />
  </main>
</BaseLayout>

<style>
  .page-intro {
    display: grid;
    gap: 0.65rem;
    max-width: 48rem;
  }

  .intro-kicker {
    color: rgb(var(--accent-dark));
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .intro-title {
    margin: 0;
    color: rgb(var(--black));
    font-size: clamp(2rem, 3.8vw, 3.6rem);
    line-height: 1.02;
    letter-spacing: -0.05em;
  }

  .intro-copy {
    margin: 0;
    max-width: 46rem;
    color: rgb(var(--gray-dark));
    font-size: 1.02rem;
    line-height: 1.75;
  }

  .intro-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
</style>
