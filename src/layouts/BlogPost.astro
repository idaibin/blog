---
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

import BaseHead from "@/components/BaseHead.astro";
import FormattedDate from "@/components/FormattedDate.astro";
import PageHeader from "@/components/PageHeader.astro";
import { type Locale, type SectionKey } from "@/site";

interface Props {
  section: SectionKey;
  title: string;
  description: string;
  pubDate: Date;
  heroImage?: ImageMetadata;
  cover?: string;
}

const currentLocale = (Astro.currentLocale || "en") as Locale;
const {
  section,
  title,
  description,
  pubDate,
  heroImage,
  cover,
} = Astro.props as Props;

const isPrompts = section === "prompts";
const copyLabel = currentLocale === "zh" ? "复制 Prompt" : "Copy prompt";
const copiedLabel = currentLocale === "zh" ? "已复制" : "Copied";
---

<html lang={currentLocale}>
  <head>
    <BaseHead title={title} description={description} image={heroImage} />
  </head>
  <body>
    <PageHeader />
    <main class="article-page">
      <header class="article-hero">
        <div class="article-date">
          <FormattedDate date={pubDate} />
        </div>
        <h1>{title}</h1>
        <p class="article-description">{description}</p>

        <div class="article-actions">
          {isPrompts && (
            <button id="copy-prompt" type="button" class="copy-chip">
              {copyLabel}
            </button>
          )}
        </div>
      </header>

      {heroImage && (
        <figure class="article-image">
          <Image
            width={1200}
            height={560}
            loading="eager"
            quality={95}
            format="webp"
            fit="cover"
            src={heroImage}
            alt={title}
          />
        </figure>
      )}

      {!heroImage && cover && (
        <figure class="article-image">
          <img src={cover} alt={title} />
        </figure>
      )}

      <article class="article-body prose" data-copy-source>
        <slot />
      </article>
    </main>
    <Analytics />
    <SpeedInsights />
    <button id="back-to-top" aria-label="Back to top" style="display:none;">
      <svg
        viewBox="64 64 896 896"
        focusable="false"
        data-icon="vertical-align-top"
        width="1em"
        height="1em"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          d="M859.9 168H164.1c-4.5 0-8.1 3.6-8.1 8v60c0 4.4 3.6 8 8.1 8h695.8c4.5 0 8.1-3.6 8.1-8v-60c0-4.4-3.6-8-8.1-8zM518.3 355a8 8 0 00-12.6 0l-112 141.7a7.98 7.98 0 006.3 12.9h73.9V848c0 4.4 3.6 8 8 8h60c4.4 0 8-3.6 8-8V509.7H624c6.7 0 10.4-7.7 6.3-12.9L518.3 355z"
        ></path>
      </svg>
    </button>
    <script is:inline define:vars={{ copyLabel, copiedLabel }}>
      const copyButton = document.getElementById("copy-prompt");
      if (copyButton) {
        copyButton.addEventListener("click", async () => {
          const source = document.querySelector("[data-copy-source]");
          const text = source?.innerText?.trim() ?? "";
          await navigator.clipboard.writeText(text);
          copyButton.textContent = copiedLabel;
          window.setTimeout(() => {
            copyButton.textContent = copyLabel;
          }, 1200);
        });
      }

      window.addEventListener("scroll", function () {
        const btn = document.getElementById("back-to-top");
        if (btn) {
          btn.style.display = window.scrollY > 200 ? "flex" : "none";
        }
      });

      const backToTopBtn = document.getElementById("back-to-top");
      if (backToTopBtn) {
        backToTopBtn.onclick = function () {
          window.scrollTo({ top: 0, behavior: "smooth" });
        };
      }
    </script>
  </body>
</html>
<style>
  .article-page {
    width: min(960px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 1.75rem 0 4rem;
    display: grid;
    gap: 1.25rem;
  }

  .article-hero {
    display: grid;
    justify-items: center;
    gap: 0.45rem;
    padding: 0 0 0.6rem;
  }

  .article-date {
    color: rgb(var(--accent-dark));
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    line-height: 1.2;
  }

  .article-hero h1 {
    margin: 0.1rem 0 0;
    color: rgb(var(--black));
    font-size: clamp(1.75rem, 2.8vw, 2.75rem);
    line-height: 1.02;
    letter-spacing: -0.05em;
    max-width: 18ch;
    text-align: center;
  }

  .article-description {
    margin: 0;
    color: rgb(var(--gray-dark));
    font-size: 0.98rem;
    line-height: 1.78;
    max-width: 62ch;
    text-align: center;
  }

  .article-actions {
    margin-top: 0.2rem;
    display: flex;
    gap: 0.75rem;
  }

  .article-image {
    margin: 0;
    overflow: hidden;
    border: 1px solid rgba(var(--black), 0.08);
    border-radius: 28px;
    background: rgba(var(--surface), 0.74);
  }

  .article-image img {
    display: block;
    width: 100%;
    height: auto;
  }

  .article-body {
    width: 100%;
    margin: 0;
    padding: 1.25rem 0 0;
    border-top: 1px solid rgba(var(--black), 0.08);
    background: transparent;
    max-width: none;
  }

  .article-body.prose {
    max-width: none;
  }

  :where([data-astro-image]) {
    object-fit: var(--fit);
    object-position: var(--pos);
  }

  :where([data-astro-image="full-width"]) {
    width: 100%;
  }

  :where([data-astro-image="constrained"]) {
    max-width: 100%;
  }

  #back-to-top {
    position: fixed;
    right: 1.5rem;
    bottom: 1.5rem;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: none;
    border-radius: 999px;
    background: rgb(var(--accent-dark));
    color: white;
    cursor: pointer;
    box-shadow: 0 14px 24px rgba(15, 18, 25, 0.16);
    transition:
      transform 0.2s ease,
      background 0.2s ease;
  }

  #back-to-top:hover {
    transform: translateY(-2px);
    background: rgb(var(--accent));
  }

  @media (max-width: 720px) {
    .article-page {
      width: min(920px, calc(100% - 1.25rem));
      padding: 1rem 0 3rem;
    }

    .article-hero h1 {
      font-size: clamp(1.95rem, 10vw, 3rem);
    }

    .article-description {
      font-size: 0.95rem;
    }

    .article-image,
    .article-body {
      border-radius: 22px;
    }
  }
</style>
