---
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";

import "@/styles.css";
import BaseHead from "@/components/BaseHead.astro";
import PageHeader from "@/components/PageHeader.astro";
import type { ImageMetadata } from "astro";
import { homeMeta, type Locale } from "@/site";

const currentLang = (Astro.currentLocale || "en") as Locale;
const isZh = currentLang === "zh";

interface Props {
    title?: string;
    description?: string;
    image?: ImageMetadata;
}

const { title, description, image } = Astro.props;

const defaultTitle = "idaibin.dev";
const defaultDescription = isZh
    ? homeMeta.zh.description
    : homeMeta.en.description;
---

<!doctype html>
<html lang={currentLang}>
    <head>
        <BaseHead
            title={title || defaultTitle}
            description={description || defaultDescription}
            image={image}
        />
    </head>
    <body>
        <PageHeader />
        <slot />
        <Analytics />
        <SpeedInsights />
    </body>
</html>
<style is:global>
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(18px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        position: relative;
        margin: 0;
        padding: 0;
        overflow-wrap: break-word;
        word-wrap: break-word;
        background:
            radial-gradient(
                circle at top left,
                rgba(var(--accent), 0.05),
                transparent 28%
            ),
            linear-gradient(180deg, rgb(var(--surface)), rgb(250, 251, 253));
        color: rgb(var(--gray-dark));
        font-family: "Atkinson", sans-serif;
        font-size: 18px;
        line-height: 1.7;
        text-align: left;
    }

    body::before {
        content: "";
        position: fixed;
        inset: 0;
        z-index: -1;
        pointer-events: none;
        background: radial-gradient(
            circle at 50% -20%,
            rgba(var(--accent), 0.08),
            transparent 42%
        );
        opacity: 0.6;
    }

    main {
        width: min(960px, calc(100% - 2rem));
        margin: 0 auto;
        padding: 2rem 0 4rem;
    }

    .page-section {
        display: flex;
        flex-direction: column;
        gap: 2rem;
        max-width: 48rem;
        animation: fadeInUp 0.48s ease both;
    }

    .page-hero {
        position: relative;
        display: grid;
        grid-template-columns: minmax(0, 1.18fr) minmax(320px, 0.82fr);
        gap: 1.5rem;
        align-items: stretch;
        overflow: hidden;
        padding: clamp(1.4rem, 2.8vw, 2.4rem);
        border: 1px solid rgba(var(--black), 0.08);
        border-radius: 32px;
        background:
            linear-gradient(
                135deg,
                rgba(var(--surface), 0.94),
                rgba(var(--surface), 0.78)
            ),
            radial-gradient(
                circle at top right,
                rgba(var(--accent), 0.16),
                transparent 34%
            ),
            radial-gradient(
                circle at bottom left,
                rgba(var(--accent-dark), 0.08),
                transparent 34%
            );
        box-shadow: 0 24px 54px rgba(15, 18, 25, 0.08);
    }

    .page-hero::before,
    .section-panel::before,
    .article-hero::before {
        content: "";
        position: absolute;
        inset: 0 auto auto 0;
        width: 100%;
        height: 1px;
        background: linear-gradient(
            90deg,
            rgba(var(--accent), 0.72),
            transparent 42%
        );
        pointer-events: none;
    }

    .page-hero::after {
        content: "";
        position: absolute;
        right: -12%;
        bottom: -38%;
        width: 280px;
        height: 280px;
        border-radius: 999px;
        background: radial-gradient(
            circle,
            rgba(var(--accent), 0.12),
            transparent 66%
        );
        pointer-events: none;
    }

    .hero-kicker,
    .section-kicker {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        color: rgb(var(--accent-dark));
        font-size: 0.76rem;
        font-weight: 800;
        letter-spacing: 0.14em;
        text-transform: uppercase;
    }

    .hero-title,
    .section-title {
        margin: 0;
        color: rgb(var(--black));
        letter-spacing: -0.05em;
        line-height: 1.02;
    }

    .hero-title {
        margin-top: 0.9rem;
        max-width: 11ch;
        font-size: clamp(2.1rem, 4.4vw, 4rem);
    }

    .hero-lead,
    .section-summary {
        margin: 1rem 0 0;
        max-width: 58ch;
        color: rgb(var(--gray-dark));
        font-size: 1.05rem;
        line-height: 1.75;
    }

    .hero-actions,
    .section-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 1.5rem;
    }

    .hero-stack,
    .module-footer,
    .article-side-list {
        display: grid;
        gap: 0.75rem;
        margin-top: 1.5rem;
    }

    .meta-line,
    .side-line {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        padding-top: 0.85rem;
        border-top: 1px solid rgba(var(--black), 0.08);
    }

    .meta-label,
    .side-label {
        color: rgb(var(--gray));
        font-size: 0.82rem;
        line-height: 1.4;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .meta-value,
    .side-value {
        color: rgb(var(--black));
        font-size: 0.98rem;
        font-weight: 700;
        line-height: 1.4;
        text-align: right;
    }

    .action-link,
    .ghost-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.85rem 1.1rem;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 700;
        transition:
            transform 0.2s ease,
            background 0.2s ease,
            border-color 0.2s ease;
    }

    .action-link {
        border: 1px solid rgb(var(--accent-dark));
        background: rgb(var(--accent-dark));
        color: white;
    }

    .action-link:hover {
        transform: translateY(-1px);
        border-color: rgb(var(--accent));
        background: rgb(var(--accent));
        color: white;
    }

    .ghost-link {
        border: 1px solid rgba(var(--black), 0.12);
        background: rgba(var(--surface), 0.72);
        color: rgb(var(--black));
    }

    .ghost-link:hover {
        transform: translateY(-1px);
        border-color: rgba(var(--accent), 0.28);
        color: rgb(var(--accent-dark));
    }

    .metric-row,
    .info-row {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
        margin-top: 1.5rem;
    }

    .metric-card,
    .info-card {
        min-width: 0;
        padding-top: 1rem;
        border-top: 1px solid rgba(var(--black), 0.08);
        background: transparent;
    }

    .metric-value {
        display: block;
        color: rgb(var(--black));
        font-size: 1.65rem;
        font-weight: 800;
        line-height: 1;
    }

    .metric-label,
    .info-label {
        display: block;
        margin-top: 0.35rem;
        color: rgb(var(--gray-dark));
        font-size: 0.85rem;
        line-height: 1.4;
    }

    .section-panel {
        position: relative;
        margin-top: 0.5rem;
        padding: 1.5rem 0 0;
    }

    .section-headline {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 1rem 1.25rem;
        align-items: end;
        margin-bottom: 1rem;
    }

    .section-title {
        font-size: clamp(1.2rem, 1.9vw, 1.6rem);
    }

    .section-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        color: rgb(var(--gray-dark));
        font-size: 0.88rem;
    }

    .chip,
    .meta-chip,
    .feed-chip,
    .copy-chip,
    .section-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.4rem 0.7rem;
        border-radius: 999px;
        font-size: 0.76rem;
        font-weight: 800;
        line-height: 1;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .chip,
    .feed-chip,
    .section-chip {
        background: rgba(var(--accent), 0.1);
        color: rgb(var(--accent-dark));
    }

    .meta-chip {
        background: rgba(15, 18, 25, 0.05);
        color: rgb(var(--gray-dark));
    }

    .copy-chip {
        border: none;
        cursor: pointer;
        background: rgb(var(--accent-dark));
        color: white;
    }

    .copy-chip:hover {
        background: rgb(var(--accent));
    }

    .module-grid {
        display: grid;
        gap: 0.9rem;
    }

    .module-card {
        display: block;
        padding: 1.15rem 1.2rem;
        border: 1px solid rgba(var(--black), 0.08);
        border-radius: 24px;
        background: linear-gradient(
            180deg,
            rgba(var(--surface), 0.94),
            rgba(var(--surface), 0.84)
        );
        box-shadow: 0 12px 30px rgba(15, 18, 25, 0.05);
        color: inherit;
        text-decoration: none;
        transition:
            transform 0.2s ease,
            color 0.2s ease,
            border-color 0.2s ease,
            box-shadow 0.2s ease;
    }

    .module-card:hover {
        transform: translateY(-2px);
        border-color: rgba(var(--accent), 0.22);
        box-shadow: 0 18px 36px rgba(15, 18, 25, 0.08);
    }

    .module-card-title {
        margin: 0.75rem 0 0;
        color: rgb(var(--black));
        font-size: 1.2rem;
        letter-spacing: -0.04em;
    }

    .module-card-copy {
        margin: 0.55rem 0 0;
        max-width: 68ch;
        color: rgb(var(--gray-dark));
        font-size: 0.96rem;
        line-height: 1.7;
    }

    .module-card-footer {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        margin-top: 0.95rem;
        color: rgb(var(--accent-dark));
        font-size: 0.88rem;
        font-weight: 700;
    }

    .feed-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1.25rem;
    }

    .feed-card {
        display: block;
        padding: 1.15rem 0 0;
        border-bottom: 1px solid rgba(var(--black), 0.08);
        color: inherit;
        text-decoration: none;
        transition:
            transform 0.2s ease,
            color 0.2s ease;
    }

    .feed-card:hover {
        transform: translateX(2px);
    }

    .feed-card-title {
        margin: 0.6rem 0 0;
        color: rgb(var(--black));
        font-size: 1.15rem;
        letter-spacing: -0.03em;
    }

    .feed-card-copy {
        margin: 0.6rem 0 0;
        color: rgb(var(--gray-dark));
        font-size: 0.96rem;
        line-height: 1.68;
    }

    .feed-card-link {
        color: rgb(var(--accent-dark));
        font-size: 0.88rem;
        font-weight: 700;
        text-decoration: none;
    }

    .hero-visual,
    .hero-visual-link {
        display: block;
        color: inherit;
        text-decoration: none;
    }

    .hero-visual {
        position: relative;
        min-height: 100%;
        overflow: hidden;
        border: 1px solid rgba(var(--black), 0.08);
        border-radius: 28px;
        background:
            linear-gradient(
                180deg,
                rgba(var(--black), 0.06),
                rgba(var(--black), 0.18)
            ),
            linear-gradient(
                135deg,
                rgba(var(--accent), 0.2),
                rgba(var(--accent-dark), 0.52)
            );
        box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.12);
    }

    .hero-visual img,
    .hero-visual picture {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .hero-visual-content {
        position: absolute;
        inset: auto 0 0;
        padding: 1.25rem;
        background: linear-gradient(
            180deg,
            transparent,
            rgba(13, 18, 28, 0.92)
        );
        color: white;
    }

    .hero-visual-title {
        margin: 0.45rem 0 0;
        font-size: 1.2rem;
        line-height: 1.3;
        letter-spacing: -0.02em;
    }

    .hero-visual-copy {
        margin: 0.55rem 0 0;
        max-width: 34ch;
        color: rgba(255, 255, 255, 0.84);
        font-size: 0.92rem;
        line-height: 1.6;
    }

    .hero-visual-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
    }

    .hero-visual-meta .section-chip {
        background: rgba(255, 255, 255, 0.12);
        color: white;
    }

    .content-rail {
        display: grid;
        gap: 1.25rem;
    }

    .content-overview {
        display: grid;
        grid-template-columns: minmax(0, 1.2fr) minmax(240px, 0.8fr);
        gap: 1rem 2rem;
        align-items: start;
    }

    .content-summary {
        max-width: 56ch;
    }

    .content-count {
        text-align: right;
    }

    .section-divider {
        border-top: 1px solid rgba(var(--black), 0.08);
        padding-top: 1.25rem;
    }

    .article-layout {
        display: grid;
        gap: 1.25rem;
    }

    .article-side {
        display: grid;
        gap: 0.75rem;
    }

    .article-side-panel {
        padding: 1.1rem 1.15rem;
        border-top: 1px solid rgba(var(--black), 0.08);
    }

    @media (max-width: 960px) {
        .page-hero {
            grid-template-columns: 1fr;
        }

        .feed-grid,
        .metric-row,
        .info-row,
        .content-overview {
            grid-template-columns: 1fr;
        }

        .content-count {
            text-align: left;
        }
    }

    @media (max-width: 720px) {
        main {
            width: min(1140px, calc(100% - 1.25rem));
            padding: 1.1rem 0 3.25rem;
        }

        body {
            font-size: 18px;
        }

        .page-hero {
            padding: 1.15rem;
            border-radius: 24px;
        }

        .hero-title {
            font-size: clamp(1.9rem, 9vw, 3rem);
        }

        .hero-lead,
        .section-summary {
            font-size: 1rem;
        }

        .section-headline {
            grid-template-columns: 1fr;
        }

        .module-card,
        .feed-card {
            padding: 1rem 0;
        }

        .action-link,
        .ghost-link {
            width: 100%;
            justify-content: center;
        }
    }

    /* 表格优化 */
    .prose table {
        width: 100%;
        min-width: 100%;
        border: 1px solid rgba(148, 163, 184, 0.6);
        border-collapse: collapse;
    }
    .prose th {
        background: rgba(241, 245, 249, 1);
        padding: 0.6rem 0.75rem;
        text-align: left;
        color: rgb(55, 65, 81);
    }
    .prose td {
        padding: 0.6rem 0.75rem;
        border-top: 1px solid rgba(226, 232, 240, 1);
    }

    /* 列表优化 */
    .prose ul,
    .prose ol {
        margin: 0;
        padding-left: 1.25rem;
    }
    .prose li::marker {
        color: rgb(79, 70, 229);
        font-weight: 700;
    }
</style>
