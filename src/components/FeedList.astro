---
import type { ImageMetadata } from "astro";

import FormattedDate from "./FormattedDate.astro";
import { sectionMeta, type Locale, type SectionKey } from "@/site";

export interface FeedItem {
    section: SectionKey;
    title: string;
    description: string;
    href: string;
    pubDate: Date;
    heroImage?: ImageMetadata;
    cover?: string;
}

export interface Props {
    items: FeedItem[];
    locale: Locale;
    emptyTitle?: string;
    emptyCopy?: string;
}

const { items, locale, emptyTitle, emptyCopy } = Astro.props;
---

<ul class="feed-list">
    {
        items.length === 0 && (
            <li class="feed-empty">
                <h2>{emptyTitle ?? "No items yet"}</h2>
                <p>{emptyCopy ?? "Add content to begin the stream."}</p>
            </li>
        )
    }
    {
        items.map((item) => (
            <li class:list={["feed-item", `section-${item.section}`]}>
                <a class="feed-link" href={item.href}>
                    <div class="feed-media">
                        <span class="feed-fallback-kicker">
                            {sectionMeta[locale][item.section].title}
                        </span>
                        <span class="feed-fallback-mark">
                            {sectionMeta[locale][item.section].title.slice(
                                0,
                                1,
                            )}
                        </span>
                        <time
                            class="feed-time"
                            datetime={item.pubDate.toISOString()}
                        >
                            <FormattedDate date={item.pubDate} />
                        </time>
                    </div>

                    <div class="feed-body">
                        <h3 class="feed-title">{item.title}</h3>
                        <p class="feed-copy">{item.description}</p>
                    </div>
                </a>
            </li>
        ))
    }
</ul>

<style>
    .feed-list {
        display: grid;
        gap: 1rem;
        margin: 0;
        padding: 0;
        list-style: none;
    }

    .feed-empty {
        padding: 1.2rem 1.25rem;
        border: 1px dashed rgba(var(--black), 0.14);
        border-radius: 24px;
        background: rgba(var(--surface), 0.72);
    }

    .feed-empty h2 {
        margin: 0 0 0.35rem;
        color: rgb(var(--black));
        font-size: 1rem;
    }

    .feed-empty p {
        margin: 0;
        color: rgb(var(--gray-dark));
        font-size: 0.95rem;
    }

    .feed-link {
        display: flex;
        overflow: hidden;
        border: 1px solid rgba(var(--black), 0.08);
        border-radius: 28px;
        background: rgba(var(--surface), 0.92);
        box-shadow: 0 12px 30px rgba(15, 18, 25, 0.05);
        color: inherit;
        text-decoration: none;
        transition:
            transform 0.22s ease,
            box-shadow 0.22s ease,
            border-color 0.22s ease;
    }

    .feed-link:hover {
        transform: translateY(-2px);
        border-color: rgba(var(--accent), 0.22);
        box-shadow: 0 18px 40px rgba(15, 18, 25, 0.08);
    }

    .feed-media {
        position: relative;
        width: 15rem;
        display: flex;
        flex-direction: column;
        background: linear-gradient(160deg, var(--tone-a), var(--tone-b));
        padding: 1.2rem;
        color: rgb(var(--black));
    }

    .feed-fallback-kicker {
        color: rgba(15, 18, 25, 0.55);
        font-size: 0.74rem;
        font-weight: 800;
        letter-spacing: 0.14em;
        text-transform: uppercase;
    }

    .feed-fallback-mark {
        font-size: clamp(3rem, 8vw, 6rem);
        font-weight: 800;
        line-height: 1;
        letter-spacing: -0.08em;
        color: rgba(15, 18, 25, 0.82);
    }

    .feed-time {
        position: absolute;
        top: 1rem;
        right: 1rem;
        z-index: 1;
        display: inline-flex;
        align-items: center;
        padding: 0.35rem 0.7rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.54);
        color: rgb(var(--accent-dark));
        font-size: 0.74rem;
        font-weight: 800;
        letter-spacing: 0.04em;
        line-height: 1;
        text-transform: uppercase;
        backdrop-filter: blur(10px);
    }

    .feed-body {
        position: relative;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        padding: 1rem;
    }

    .feed-title {
        margin: 0;
        color: rgb(var(--black));
        font-size: clamp(1.2rem, 1.8vw, 1.75rem);
        line-height: 1.12;
        letter-spacing: -0.05em;
        display: -webkit-box;
        overflow: hidden;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 2;
    }

    .feed-copy {
        margin: 0;
        max-width: 68ch;
        color: rgb(var(--gray-dark));
        font-size: 0.95rem;
        line-height: 1.68;
        display: -webkit-box;
        overflow: hidden;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 2;
    }

    .section-prompts {
        --tone-a: rgba(241, 232, 255, 1);
        --tone-b: rgba(225, 212, 255, 1);
    }

    .section-skills {
        --tone-a: rgba(229, 246, 238, 1);
        --tone-b: rgba(205, 236, 224, 1);
    }

    .section-notes {
        --tone-a: rgba(238, 241, 247, 1);
        --tone-b: rgba(222, 229, 239, 1);
    }

    @media (max-width: 768px) {
        .feed-link {
            display: flex;
            flex-direction: column;
        }

        .feed-media {
            width: 100%;
            height: 160px;
            min-height: 160px;
        }

        .feed-body {
            padding: 1.2rem;
        }
    }

    @media (max-width: 480px) {
        .feed-link {
            border-radius: 20px;
        }

        .feed-media {
            height: 140px;
        }

        .feed-fallback-mark {
            font-size: clamp(2rem, 5vw, 4rem);
        }

        .feed-title {
            font-size: clamp(1rem, 1.5vw, 1.4rem);
        }

        .feed-copy {
            font-size: 0.9rem;
            line-height: 1.6;
        }
    }
</style>
