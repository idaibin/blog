---
import LanguageSwitcher from "./LanguageSwitcher.astro";
import SocialLinks from "./SocialLinks.astro";
import { getRelativeLocaleUrl } from "astro:i18n";
import { getSectionPath, sectionMeta, sections, type Locale } from "@/site";

const currentLang = (Astro.currentLocale || "en") as Locale;
const title = "idaibin.dev";
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, "/");
const prefix = currentLang === "zh" ? "/zh" : "";
const isHome =
    currentLang === "zh"
        ? pathname === "/zh" ||
          pathname === "/zh/" ||
          pathname.startsWith("/zh/page/")
        : pathname === "/" || pathname === "" || pathname.startsWith("/page/");

const getNavLink = (path: string) => getRelativeLocaleUrl(currentLang, path);

const navItems = [
    {
        label: currentLang === "zh" ? "全部" : "All",
        href: getNavLink("/"),
        active: isHome,
    },
    ...sections.map((section) => ({
        label: sectionMeta[currentLang][section].title,
        href: getSectionPath(section, currentLang),
        active: pathname.startsWith(`${prefix}/${section}`),
    })),
];
---

<header>
    <nav>
        <div class="nav-brand">
            <h2><a href={getNavLink("/")}>{title}</a></h2>
        </div>
        <div class="nav-tabs" aria-label="Primary">
            {
                navItems.map((item) => (
                    <a
                        href={item.href}
                        class:list={["nav-tab", { active: item.active }]}
                        aria-current={item.active ? "page" : undefined}
                    >
                        {item.label}
                    </a>
                ))
            }
        </div>
        <div class="nav-right">
            <SocialLinks />
            <LanguageSwitcher />
        </div>
    </nav>
</header>
<style>
    header {
        position: sticky;
        top: 0;
        z-index: 20;
        margin: 0;
        padding: 0;
        background: rgba(var(--surface), 0.74);
        backdrop-filter: blur(18px);
        border-bottom: 1px solid rgba(var(--black), 0.08);
    }
    h2 {
        margin: 0;
        font-size: 0.95rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    h2 a,
    h2 a.active {
        text-decoration: none;
        color: rgb(var(--black));
    }
    nav {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 1rem;
        width: min(960px, calc(100% - 2rem));
        margin: 0 auto;
        min-height: 3.9rem;
    }

    .nav-brand {
        justify-self: start;
    }

    .nav-tabs {
        display: flex;
        align-items: center;
        gap: 1rem;
        justify-content: center;
        min-width: 0;
        justify-self: center;
        overflow-x: auto;
        scrollbar-width: none;
        padding: 0.45rem 0;
    }

    .nav-tabs::-webkit-scrollbar {
        display: none;
    }

    .nav-tab {
        color: rgb(var(--gray-dark));
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 500;
        white-space: nowrap;
        padding: 0.25rem 0;
        border-bottom: 2px solid transparent;
        transition:
            color 0.2s ease,
            border-color 0.2s ease;
    }

    .nav-tab:hover {
        color: rgb(var(--black));
    }

    .nav-tab.active {
        color: rgb(var(--black));
        border-bottom-color: rgb(var(--accent));
        font-weight: 700;
    }

    .nav-right {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        justify-self: end;
    }
    @media (max-width: 720px) {
        header {
            padding: 0;
        }
        nav {
            grid-template-columns: auto 1fr;
            grid-template-areas:
                "brand right"
                "tabs tabs";
            align-items: center;
            width: min(960px, calc(100% - 1.25rem));
            padding: 0.25rem 0 0.3rem;
        }
        .nav-brand {
            grid-area: brand;
        }
        .nav-right {
            grid-area: right;
            justify-self: end;
        }
        .nav-tabs {
            grid-area: tabs;
            width: 100%;
            justify-content: flex-start;
            padding: 0 0 0.35rem;
            gap: 0.85rem;
        }
        h2 a {
            display: inline-block;
            padding: 0.85rem 0 0.35rem;
        }
        .nav-right {
            gap: 0.45rem;
        }
    }
</style>
